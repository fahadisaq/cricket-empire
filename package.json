    "db:reseed": "tsx src/scripts/supabase.ts reseed",
    "db:tick": "tsx src/scripts/supabase.ts tick",
    "test": "tsx src/engine/engine.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@vercel/node": "^3.2.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "cors": "^2.8.5",
    "express": "^4.21.1"
