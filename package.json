{
  "name": "cricket-empire",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A deep T20 cricket management sim — powerful engine + self-managing AI clubs.",
  "scripts": {
    "season": "tsx src/cli.ts season",
